#1) install n load packages
install.packages(c("tidyverse", "lubridate", "stringi"))
setwd("C:/Users/User/Documents/GitHub/TEB2043_DS_24006963/Lab_Project/200226_P1_Data_Cleaning")
#1) install n load packages
install.packages(c("tidyverse", "lubridate", "stringi"))
library(tidyverse)
library(lubridate)
library(stringi)
library(readr)
#2) Read CSV
#Read lines while telling readr the file's encoding (Windows-1252 is a safe bet for £)
raw_lines <- readr::read_lines(
"Unclean Dataset.csv",
locale = readr::locale(encoding = "Windows-1252"),
progress = FALSE
)
#Convert to UTF-8 so downstream string ops are happy
raw_lines <- stringi::stri_enc_toutf8(raw_lines)
# 2.1 Normalise strange backslash line breaks like "101 \"
raw_lines <- gsub("\\s*\\\\\\s*$", "", raw_lines)  # remove trailing " \"
raw_lines <- gsub("\\s*\\\\", " ", raw_lines)      # stray backslashes -> space
# 2.2 Convert repeated ",,,,,," artifacts to a single comma
raw_lines <- gsub(",{2,}", ",", raw_lines)
# 2.3 Trim leading/trailing whitespace and stray quotes
raw_lines <- stri_trim_both(raw_lines)
# 2.4 Collapse multiple spaces around commas
raw_lines <- gsub("\\s*,\\s*", ",", raw_lines)
# 2.5 Write to a temp cleaned text, then parse as CSV
temp_file <- "tmp_normalized.csv"
writeLines(raw_lines, temp_file)
# Now read with readr; allow quoted fields, guess max cols
df_raw <- readr::read_csv(
temp_file,
col_names = TRUE,
na = c("NA", "", "null", "Null", "NULL", "N/A", "na")
)
#3) Standardise column names
target_names <- c("Student_ID","First_Name","Last_Name",
"Age","Gender","Course","Enrollment_Date","Total_Payments")
# If df_raw has more/less columns, fix by selecting/adding NAs
if (ncol(df_raw) < length(target_names)) {
df_raw[(ncol(df_raw)+1):length(target_names)] <- NA
}
names(df_raw)[1:length(target_names)] <- target_names
df_raw <- df_raw[, target_names]
#4) Trim whitespace, unify text casing
trim2 <- function(x) str_squish(str_replace_all(x, "\\s+", " "))
df <- df_raw %>%
mutate(
across(c(First_Name, Last_Name, Gender, Course, Enrollment_Date, Total_Payments),
~ ifelse(is.na(.), NA, trim2(as.character(.))))
)
#5) Fix typos
course_map <- c(
"data science"      = "Data Science",
"machine learning"  = "Machine Learning",
"data analytics"    = "Data Analytics",
"data analysis"     = "Data Analytics",
"web development"   = "Web Development",
"web developmen"    = "Web Development",
"web developmet"    = "Web Development",
"web develpment"    = "Web Development",
"cyber security"    = "Cyber Security"
)
df <- df %>%
mutate(
Course_clean = str_to_lower(Course),
Course_clean = str_replace_all(Course_clean, "learnin\\b", "learning"),
Course_clean = trim2(Course_clean),
Course = coalesce(course_map[Course_clean], str_to_title(Course_clean))
) %>%
select(-Course_clean)
#6) Normalise gender M/F
df <- df %>%
mutate(
Gender = case_when(
str_to_lower(Gender) %in% c("m", "male") ~ "M",
str_to_lower(Gender) %in% c("f", "female") ~ "F",
TRUE ~ NA_character_
)
)
#7) Clean Age
df <- df %>%
mutate(
Age = as.numeric(str_extract(as.character(Age), "\\d+")),  # keep digits only
Age = ifelse(Age < 16 | Age > 60, NA, Age)
)
#8) Clean Payment to be numeric
df <- df %>%
mutate(
Total_Payments = str_replace_all(Total_Payments, "\\$|\\?|\\s", ""),
Total_Payments = str_replace_all(Total_Payments, ",", ""),
Total_Payments = na_if(Total_Payments, ""),
Total_Payments = as.numeric(Total_Payments)
)
#9) Parse date
parse_multi_date <- function(x) {
x <- trim2(x)
# Try ISO first, then dmy/mdy with both numeric and month names
y <- suppressWarnings(ymd(x))
y <- ifelse(is.na(y), suppressWarnings(dmy(x)), y)
y <- ifelse(is.na(y), suppressWarnings(mdy(x)), y)
# Convert character back to Date
as.Date(y, origin = "1970-01-01")
}
df <- df %>%
mutate(
Enrollment_Date = ifelse(is.na(Enrollment_Date) | Enrollment_Date %in% c("NA",""), NA, Enrollment_Date),
Enrollment_Date = parse_multi_date(Enrollment_Date)
)
#10) Detect and remove duplicate rows
n_before <- nrow(df)
# Remove exact duplicate rows
df <- distinct(df)
# Also remove duplicates by a composite key likely to define a unique record
df <- df %>%
distinct(Student_ID, First_Name, Last_Name, Age, Gender, Course, Enrollment_Date, Total_Payments, .keep_all = TRUE)
n_after <- nrow(df)
message("Removed duplicates: ", n_before - n_after)
#11) Handle missing values
# Median age (ignoring NAs)
age_median <- median(df$Age, na.rm = TRUE)
# Median payment per course (named vector)
med_by_course <- df %>%
group_by(Course) %>%
summarize(med = median(Total_Payments, na.rm = TRUE)) %>%
deframe()
global_med <- median(df$Total_Payments, na.rm = TRUE)
df <- df %>%
mutate(
Age = ifelse(is.na(Age), age_median, Age),
Total_Payments = case_when(
!is.na(Total_Payments) ~ Total_Payments,
is.na(Total_Payments) & !is.na(Course) & !is.na(med_by_course[Course]) ~ med_by_course[Course],
TRUE ~ global_med
)
)
#12) Basic data type casting & sanity constraints
df <- df %>%
mutate(
Student_ID = suppressWarnings(as.integer(Student_ID)),
First_Name = ifelse(is.na(First_Name) | First_Name == "", NA, First_Name),
Last_Name  = ifelse(is.na(Last_Name)  | Last_Name  == "", NA, Last_Name),
Course     = ifelse(is.na(Course)     | Course     == "", NA, Course)
)
# drop rows still missing critical fields
df <- df %>% drop_na(Student_ID, First_Name, Last_Name, Course, Enrollment_Date, Gender)
#13) Final QC
# 13.1 Null counts per column
colSums(is.na(df))
# 13.2 Duplicates check
sum(duplicated(df))
# 13.3 Types and a quick peek
glimpse(df)
summary(df)
# 13.4 Simple logical checks
range(df$Age, na.rm = TRUE)
table(df$Gender, useNA = "ifany")
table(df$Course, useNA = "ifany")
#14) Save into clean dataset csv
write_csv(df, "clean_dataset.csv", na = "")
#install n load packages
install.packages(c("dplyr", "tidyr", "stringr"))
library(dplyr)
library(tidyr)
library(stringr)
#load dataset
df <- read.csv("Unclean Dataset.csv", stringsAsFactors = FALSE)
# Basic inspection
cat("Sum of duplicates:", sum(duplicated(df)), "\n")
print(colSums(is.na(df)))
str(df)
summary(df)
head(df)
#remove duplicates
df <- df %>% distinct()
cat("Successful duplicate removal.\n")
#handle missing values
get_mode <- function(v) {
uniqv <- unique(v[!is.na(v)])
uniqv[which.max(tabulate(match(v, uniqv)))]
}
df <- df %>%
mutate(across(where(is.character), ~replace(., is.na(.), get_mode(.)))) %>%
mutate(across(where(is.numeric), ~replace(., is.na(.), median(., na.rm = TRUE))))
cat("Missing values successfully handled.\n")
#convert column data type accordingly
df <- df %>%
mutate(across(everything(), function(x) {
out <- suppressWarnings(as.numeric(x))
if (all(is.na(out))) x else out
}))
# install n load packages
install.packages(c("dplyr", "tidyr", "stringr"))
library(dplyr)
library(tidyr)
library(stringr)
# Load dataset
df <- read.csv("Unclean Dataset.csv",
stringsAsFactors = FALSE,
fileEncoding = "latin1")
# Normalize all character columns to UTF-8 (one-liner, keeps non-chars unchanged)
df[] <- lapply(df, function(x) if (is.character(x)) enc2utf8(x) else x)
# Clean special characters in Total_Payments
if ("Total_Payments" %in% names(df)) {
df$Total_Payments <- df$Total_Payments %>%
trimws() %>%                      # remove leading/trailing spaces
str_replace_all("[^0-9.,-]", "") %>%  # remove currency symbols/spaces
str_replace_all(",", "") %>%      # drop thousands separators
suppressWarnings(as.numeric())    # now safe to turn numeric
}
# Basic inspection
cat("Sum of duplicates:", sum(duplicated(df)), "\n")
print(colSums(is.na(df)))
str(df)
summary(df)
head(df)
# remove duplicates
df <- df %>% distinct()
cat("Successful duplicate removal.\n")
# handle missing values
get_mode <- function(v) {
uniqv <- unique(v[!is.na(v)])
uniqv[which.max(tabulate(match(v, uniqv)))]
}
df <- df %>%
mutate(across(where(is.character), ~replace(., is.na(.), get_mode(.)))) %>%
mutate(across(where(is.numeric), ~replace(., is.na(.), median(., na.rm = TRUE))))
cat("Missing values successfully handled.\n")
# convert column data type accordingly (robust: only convert if it looks numeric)
df <- df %>%
mutate(across(everything(), function(x) {
if (is.character(x)) {
x_clean <- str_replace_all(x, ",", "")
# if the non-empty values are all numeric-like after comma removal, convert
if (all(grepl("^\\s*$|^[-+]?\\d*(?:\\.\\d+)?$", x_clean))) {
return(suppressWarnings(as.numeric(x_clean)))
}
} else {
# keep existing numerics as is
return(x)
}
x
}))
cat("Successfully converted data types accordingly.\n")
# handle outliers using IQR
df_numeric <- df %>% select(where(is.numeric))
Q1 <- apply(df_numeric, 2, quantile, 0.25, na.rm = TRUE)
Q3 <- apply(df_numeric, 2, quantile, 0.75, na.rm = TRUE)
IQR <- Q3 - Q1
cat("Successfully handled outliers using IQR method.\n")
# remove rows with outliers
df_cleaned <- df %>%
filter(!apply(df_numeric, 1, function(row) {
any(row < (Q1 - 1.5 * IQR) | row > (Q3 + 1.5 * IQR))
}))
cat("Successfully removed outliers.\n")
# save cleaned dataset
write.csv(df_cleaned, "Cleaned_Dataset.csv", row.names = FALSE)
cat("Cleaned dataset saved as 'Cleaned_Dataset.csv'\n")
# final checking
cat("Sum of duplicates:", sum(duplicated(df_cleaned)), "\n")
print(colSums(is.na(df_cleaned)))
str(df_cleaned)
summary(df_cleaned)
head(df_cleaned)
# install n load packages
install.packages(c("dplyr", "tidyr", "stringr"))
library(dplyr)
library(tidyr)
library(stringr)
# Load dataset (tolerant encoding)
df <- read.csv("Unclean Dataset.csv",
stringsAsFactors = FALSE,
fileEncoding = "latin1")
# Normalise all character columns to UTF-8 (one-liner, keeps non-chars unchanged)
df[] <- lapply(df, function(x) if (is.character(x)) enc2utf8(x) else x)
# Clean special characters in Total_Payments
if ("Total_Payments" %in% names(df)) {
df$Total_Payments <- df$Total_Payments %>%
trimws() %>%                         # remove leading/trailing spaces
str_replace_all("[^0-9.,-]", "") %>% # remove currency symbols/spaces
str_replace_all(",", "") %>%         # drop thousands separators
suppressWarnings(as.numeric())       # now safe to turn numeric
}
# Ensure expected columns exist
required_cols <- c("Student_ID","First_Name","Last_Name","Age","Gender")
for (nm in required_cols) if (!nm %in% names(df)) df[[nm]] <- NA_character_
# Trim and squish whitespace on key cols
df <- df %>%
mutate(across(all_of(required_cols),
~ ifelse(is.na(.), "", str_squish(.))))
# 1) STUDENT_ID: extract digits; convert to integer
df <- df %>%
mutate(Student_ID = suppressWarnings(as.integer(str_extract(Student_ID, "\\d+"))))
# 2) NAMES: if Last_Name is empty and First_Name has ≥2 tokens, split the LAST token to Last_Name
df <- df %>%
mutate(
.full = if_else((Last_Name == "" | is.na(Last_Name)) & str_detect(First_Name, "\\s+"),
First_Name, NA_character_),
Last_Name  = if_else(!is.na(.full), str_replace(.full, "^.*\\s+(\\S+)$", "\\1"), Last_Name),
First_Name = if_else(!is.na(.full), str_replace(.full, "\\s+\\S+$", ""), First_Name)
) %>%
select(-.full)
# 3) GENDER & AGE: extract numbers to Age and M/F to Gender from either column
df <- df %>%
mutate(
age_from_age    = str_extract(Age, "\\d+"),
age_from_gender = str_extract(Gender, "\\d+"),
Age             = suppressWarnings(as.numeric(coalesce(age_from_age, age_from_gender))),
g_from_gender   = str_extract(Gender, "(?i)[mf]"),
g_from_age      = str_extract(Age %>% as.character(), "(?i)[mf]"),
Gender          = toupper(coalesce(g_from_gender, g_from_age)),
Gender          = if_else(Gender %in% c("M","F"), Gender, NA_character_)
) %>%
select(-age_from_age, -age_from_gender, -g_from_gender, -g_from_age)
# Backfill missing Student_IDs with sequential integers
if (all(is.na(df$Student_ID))) {
df$Student_ID <- 1000L + seq_len(nrow(df))
} else if (anyNA(df$Student_ID)) {
start   <- suppressWarnings(max(df$Student_ID, na.rm = TRUE))
if (!is.finite(start)) start <- 1000L
n_miss  <- sum(is.na(df$Student_ID))
df$Student_ID[is.na(df$Student_ID)] <- seq.int(from = start + 1L, length.out = n_miss)
}
# Basic inspection
cat("Sum of duplicates:", sum(duplicated(df)), "\n")
print(colSums(is.na(df)))
str(df)
summary(df)
head(df)
# remove duplicates
df <- df %>% distinct()
cat("Successful duplicate removal.\n")
# handle missing values
get_mode <- function(v) {
uniqv <- unique(v[!is.na(v)])
uniqv[which.max(tabulate(match(v, uniqv)))]
}
df <- df %>%
mutate(across(where(is.character), ~replace(., is.na(.), get_mode(.)))) %>%
mutate(across(where(is.numeric),   ~replace(., is.na(.), median(., na.rm = TRUE))))
cat("Missing values successfully handled.\n")
# convert column data type accordingly (robust: only convert if it looks numeric)
df <- df %>%
mutate(across(everything(), function(x) {
if (is.character(x)) {
x_clean <- str_replace_all(x, ",", "")
# if the non-empty values are all numeric-like after comma removal, convert
if (all(grepl("^\\s*$|^[-+]?\\d*(?:\\.\\d+)?$", x_clean))) {
return(suppressWarnings(as.numeric(x_clean)))
}
} else {
# keep existing numerics as is
return(x)
}
x
}))
cat("Successfully converted data types accordingly.\n")
# handle outliers using IQR
df_numeric <- df %>% select(where(is.numeric))
Q1  <- apply(df_numeric, 2, quantile, 0.25, na.rm = TRUE)
Q3  <- apply(df_numeric, 2, quantile, 0.75, na.rm = TRUE)
IQR <- Q3 - Q1
cat("Successfully handled outliers using IQR method.\n")
# remove rows with outliers
df_cleaned <- df %>%
filter(!apply(df_numeric, 1, function(row) {
any(row < (Q1 - 1.5 * IQR) | row > (Q3 + 1.5 * IQR))
}))
cat("Successfully removed outliers.\n")
# save cleaned dataset
write.csv(df_cleaned, "Cleaned_Dataset.csv", row.names = FALSE)
cat("Cleaned dataset saved as 'Cleaned_Dataset.csv'\n")
# final checking
cat("Sum of duplicates:", sum(duplicated(df_cleaned)), "\n")
print(colSums(is.na(df_cleaned)))
str(df_cleaned)
summary(df_cleaned)
head(df_cleaned)
