locale = readr::locale(encoding = "Windows-1252"),
progress = FALSE
)
#Convert to UTF-8 so downstream string ops are happy
raw_lines <- stringi::stri_enc_toutf8(raw_lines)
# 2.1 Normalise strange backslash line breaks like "101 \"
raw_lines <- gsub("\\s*\\\\\\s*$", "", raw_lines)  # remove trailing " \"
raw_lines <- gsub("\\s*\\\\", " ", raw_lines)      # stray backslashes -> space
# 2.2 Convert repeated ",,,,,," artifacts to a single comma
raw_lines <- gsub(",{2,}", ",", raw_lines)
# 2.3 Trim leading/trailing whitespace and stray quotes
raw_lines <- stri_trim_both(raw_lines)
# 2.4 Collapse multiple spaces around commas
raw_lines <- gsub("\\s*,\\s*", ",", raw_lines)
# 2.5 Write to a temp cleaned text, then parse as CSV
temp_file <- "tmp_normalized.csv"
writeLines(raw_lines, temp_file)
